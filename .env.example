# ============================================================
# .env.example — UrbanMove Analytics
# ============================================================
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#
# .env should be in .gitignore and NEVER committed.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=urbanmove
POSTGRES_PASSWORD=changeme_strong_password

# --- Airflow ---
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=changeme_generate_a_real_fernet_key
# Any long random string works here (used to sign Flask session cookies)
AIRFLOW_SECRET_KEY=changeme_generate_a_random_string

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_admin_password
